      "type": "text",
      "x": 698,
      "y": 40,
      "width": 624.8000000000001,
      "height": 22.4,
      "text": "Aucun handler ne bloque. Le commit lourd tourne sur un thread task. Les",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
